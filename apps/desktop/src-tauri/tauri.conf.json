{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gyro",
  "version": "0.1.0-alpha.10",
  "identifier": "dev.gyro.desktop",
  "build": {
    "beforeDevCommand": "pnpm exec vite --host 127.0.0.1",
    "beforeBuildCommand": "pnpm exec vite build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Gyro",
        "width": 1280,
        "height": 820,
        "minWidth": 860,
        "minHeight": 620,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 28
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost; frame-src http://localhost:* http://127.0.0.1:* https:"
    },
    "macOSPrivateApi": false
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "DeveloperTool",
    "copyright": "Copyright Gyro contributors",
    "createUpdaterArtifacts": true,
    "externalBin": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcwOTdENjgxOTc4NTI5ODYKUldTR0tZV1hnZGFYY0pkRTJpSmk1MUtkQ0dSUldJSE5JNy9JVCs4dmJBZnNTa0JRU3A4RWR6TEgK",
      "endpoints": [
        "https://github.com/wytzeh197/Gyro/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
