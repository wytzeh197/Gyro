{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gyro",
  "version": "0.1.0",
  "identifier": "dev.gyro.desktop",
  "build": {
    "beforeDevCommand": "pnpm exec vite --host 127.0.0.1",
    "beforeBuildCommand": "pnpm exec vite build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Gyro",
        "width": 1280,
        "height": 820,
        "minWidth": 860,
        "minHeight": 620,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 28
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost"
    },
    "macOSPrivateApi": false
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "DeveloperTool",
    "copyright": "Copyright Gyro contributors",
    "createUpdaterArtifacts": true,
    "externalBin": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "GYRO_DEV_UPDATER_PUBKEY_REPLACE_BEFORE_RELEASE",
      "endpoints": [
        "https://updates.gyro.dev/{{target}}/{{arch}}/{{current_version}}"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
